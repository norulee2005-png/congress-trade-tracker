# Neon PostgreSQL connection string (free tier at neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Secret to protect the Vercel cron endpoints
CRON_SECRET=your-random-secret-here

# JWT secret for session tokens (generate: openssl rand -base64 32)
JWT_SECRET=your-random-jwt-secret-here

# Stripe (revenue-based fees only — no fixed cost)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Resend email (free: 100 emails/day)
RESEND_API_KEY=re_...
FROM_EMAIL=alerts@yourdomain.com

# App URLs (used in magic link emails and OG images)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Financial Modeling Prep API (free tier: 250 req/day at financialmodelingprep.com)
FMP_API_KEY=your-fmp-api-key-here
